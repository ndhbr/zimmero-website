---
const screenshots = [
  { src: '/assets/zimmerplan.webp', alt: 'Zimmero Zimmerplan Wochenansicht mit Buchungen, Zimmerwechseln und blockierten Zimmern', caption: 'Zimmerplan mit Aufenthalten, Sperrzeiten und schneller Bearbeitung.' },
  { src: '/assets/buchungsuebersicht.webp', alt: 'Zimmero Buchungsübersicht mit Gästedaten, Status und Leistungen', caption: 'Alle Details einer Buchung auf einen Blick.' },
  { src: '/assets/preischeck.webp', alt: 'Zimmero Preischeck für telefonische Anfragen', caption: 'Preischeck: Verfügbarkeit und Preise in Sekunden prüfen.' },
  { src: '/assets/rechnungen.webp', alt: 'Zimmero Rechnungseditor mit Split Billing, PDF-Export und Gastronomie-Positionen', caption: 'Rechnungen erstellen, aufteilen und als PDF archivieren.' },
  { src: '/screenshots/zimmero-housekeeping.webp', alt: 'Zimmero Housekeeping-Liste mit Zimmer-Status', caption: 'Housekeeping: offene Aufgaben und Status auf einen Blick.' },
  { src: '/assets/meldescheine.webp', alt: 'Zimmero Meldeschein-Übersicht mit Status und OMS-Übermittlung', caption: 'Digitaler Meldeschein mit Gästedaten und Status.' },
  { src: '/assets/gastronomie.webp', alt: 'Zimmero Gastronomie mit Zimmerzuordnung und Produktkacheln', caption: 'Gastronomie per Tablet: Speisen und Getränke direkt aufs Zimmer buchen.' },
  { src: '/assets/statistiken.webp', alt: 'Zimmero Statistiken mit Auslastung, ADR, RevPAR und IDEV-CSV-Export', caption: 'Statistiken: Auslastung, Kennzahlen und Bayern-CSV direkt exportieren.' },
  { src: '/assets/online-direktbuchung.webp', alt: 'Zimmero Online-Direktbuchung für Hotelwebsites mit Zimmerauswahl', caption: 'Online-Direktbuchung: Gäste buchen direkt über Ihre Website.' },
];
---

<section class="py-16 md:py-24 bg-surface">
  <div class="section-container">
    <div class="max-w-3xl mx-auto text-center mb-12">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">
        Modern genug für heute. Einfach genug für den Alltag.
      </h2>
      <p class="text-secondary-600 leading-relaxed">
        Zimmero setzt auf eine klare Oberfläche, die am Desktop, Tablet und an der Rezeption funktioniert. Echte Produkt-Screenshots stehen im Vordergrund.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
      {screenshots.map((shot, i) => (
        <figure class="bg-white rounded-xl border border-secondary-200 shadow-sm overflow-hidden">
          <button
            type="button"
            class="screenshot-trigger block w-full aspect-[16/10] bg-secondary-100 relative group cursor-zoom-in"
            data-src={shot.src}
            data-alt={shot.alt}
            aria-label={`Bild vergrößern: ${shot.alt}`}
          >
            <img
              src={shot.src}
              alt={shot.alt}
              width="640"
              height="400"
              class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
              loading="lazy"
              onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
            />
            <div class="absolute inset-0 items-center justify-center bg-gradient-to-br from-primary-50 to-secondary-50 hidden">
              <div class="text-center p-4">
                <svg class="w-8 h-8 text-primary-300 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                <p class="text-xs text-secondary-400">Screenshot folgt</p>
              </div>
            </div>
            <div class="absolute inset-0 flex items-center justify-center bg-gradient-to-br from-primary-50 to-secondary-50 screenshot-placeholder">
              <div class="text-center p-4">
                <svg class="w-8 h-8 text-primary-300 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                <p class="text-xs text-secondary-400">Screenshot folgt</p>
              </div>
            </div>
            <!-- Zoom icon overlay -->
            <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-200 bg-black/20">
              <div class="bg-white/90 rounded-full p-2.5 shadow-lg">
                <svg class="w-5 h-5 text-secondary-800" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7" />
                </svg>
              </div>
            </div>
          </button>
          <figcaption class="p-4 text-sm text-secondary-600">{shot.caption}</figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<!-- Lightbox -->
<div
  id="screenshot-lightbox"
  class="fixed inset-0 z-50 flex items-center justify-center p-4 md:p-8 bg-black/80 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-200"
  role="dialog"
  aria-modal="true"
  aria-label="Bild-Vollansicht"
>
  <button
    id="lightbox-close"
    type="button"
    class="absolute top-4 right-4 bg-white/10 hover:bg-white/20 text-white rounded-full p-2 transition-colors"
    aria-label="Schließen"
  >
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>
  <img
    id="lightbox-img"
    src=""
    alt=""
    class="max-w-full max-h-full rounded-lg shadow-2xl object-contain"
  />
</div>

<script>
  document.querySelectorAll('.screenshot-placeholder').forEach(placeholder => {
    const img = placeholder.previousElementSibling?.previousElementSibling as HTMLImageElement;
    if (img?.tagName === 'IMG' && img.complete && img.naturalWidth > 0) {
      placeholder.remove();
    } else if (img?.tagName === 'IMG') {
      img.addEventListener('load', () => placeholder.remove());
    }
  });

  const lightbox = document.getElementById('screenshot-lightbox') as HTMLElement;
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const closeBtn = document.getElementById('lightbox-close') as HTMLElement;

  function openLightbox(src: string, alt: string) {
    lightboxImg.src = src;
    lightboxImg.alt = alt;
    lightbox.classList.remove('opacity-0', 'pointer-events-none');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox.classList.add('opacity-0', 'pointer-events-none');
    document.body.style.overflow = '';
  }

  document.querySelectorAll<HTMLButtonElement>('.screenshot-trigger').forEach(btn => {
    btn.addEventListener('click', () => {
      const src = btn.dataset.src ?? '';
      const alt = btn.dataset.alt ?? '';
      if (src) openLightbox(src, alt);
    });
  });

  closeBtn.addEventListener('click', closeLightbox);

  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLightbox();
  });
</script>
