---
import { CONTACT_EMAIL, DEMO_URL } from '../config';
const currentYear = new Date().getFullYear();
---

<footer class="bg-secondary-900 text-secondary-300">
  <div class="section-container py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 md:gap-12">
      <div class="md:col-span-2">
        <a href="/" class="flex items-center gap-2 mb-4">
          <img src="/logo.svg" alt="Zimmero Logo" width="28" height="28" class="w-7 h-7" />
          <span class="text-lg font-semibold text-white">Zimmero</span>
        </a>
        <p class="text-secondary-400 text-sm leading-relaxed max-w-sm">
          Moderne Betriebssoftware für inhabergeführte Hotels. Zimmerplan, Buchungen, Rechnungen, Housekeeping und mehr in einem System.
        </p>
      </div>

      <div>
        <h4 class="text-white font-medium text-sm mb-4">Produkt</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/#funktionen" class="hover:text-white transition-colors">Funktionen</a></li>
          <li><a href="/#zielgruppe" class="hover:text-white transition-colors">Für wen</a></li>
          <li><a href="/preise" class="hover:text-white transition-colors">Preise</a></li>
          <li><a href={DEMO_URL} target="_blank" rel="noopener" class="hover:text-white transition-colors">Demo</a></li>
          <li><a href="/#roadmap" class="hover:text-white transition-colors">Roadmap</a></li>
          <li><a href="/#faq" class="hover:text-white transition-colors">FAQ</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-white font-medium text-sm mb-4">Rechtliches</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/impressum" class="hover:text-white transition-colors">Impressum</a></li>
          <li><a href="/datenschutz" class="hover:text-white transition-colors">Datenschutz</a></li>
          <li><a href={`mailto:${CONTACT_EMAIL}`} class="hover:text-white transition-colors">{CONTACT_EMAIL}</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-secondary-700 text-sm text-secondary-500 text-center">
      &copy; {currentYear} Zimmero. Alle Rechte vorbehalten.
    </div>
  </div>
</footer>
