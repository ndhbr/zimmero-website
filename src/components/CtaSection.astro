---
import { DEMO_URL, CONTACT_EMAIL } from '../config';
---

<section class="py-16 md:py-24 bg-primary-500">
  <div class="section-container text-center">
    <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">
      Bereit für weniger Zettelwirtschaft im Hotelalltag?
    </h2>
    <p class="text-primary-100 leading-relaxed mb-8 max-w-2xl mx-auto">
      Testen Sie Zimmero in der Demo oder fragen Sie einen Platz in der begleiteten Pilotphase an.
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
      <a href={DEMO_URL} target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-2 px-8 py-3.5 rounded-full bg-white text-primary-600 font-semibold hover:bg-primary-50 transition-colors shadow-lg">
        Demo öffnen
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
      <a href={`mailto:${CONTACT_EMAIL}?subject=Anfrage%3A%20Zimmero%20bekommen`} class="inline-flex items-center justify-center px-8 py-3.5 rounded-full border border-white/30 text-white font-semibold hover:bg-primary-400 transition-colors">
        Pilotphase anfragen
      </a>
    </div>
  </div>
</section>
