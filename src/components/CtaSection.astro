---
import { DEMO_URL, CONTACT_EMAIL } from '../config';
---

<section class="py-16 md:py-24 bg-primary-500">
  <div class="section-container text-center">
    <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">
      Bereit für weniger Zettelwirtschaft im Hotelalltag?
    </h2>
    <p class="text-primary-100 leading-relaxed mb-8 max-w-2xl mx-auto">
      Testen Sie Zimmero in der Demo oder fragen Sie einen Platz in der begleiteten Pilotphase an.
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
      <a href={DEMO_URL} target="_blank" rel="noopener" class="inline-flex items-center justify-center px-8 py-3.5 rounded-full bg-white text-primary-600 font-semibold hover:bg-primary-50 transition-colors shadow-lg">
        Demo öffnen
      </a>
      <a href={`mailto:${CONTACT_EMAIL}?subject=Pilotphase%20anfragen`} class="inline-flex items-center justify-center px-8 py-3.5 rounded-full border border-white/30 text-white font-semibold hover:bg-primary-400 transition-colors">
        Pilotphase anfragen
      </a>
    </div>
  </div>
</section>
