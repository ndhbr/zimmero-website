<section id="funktionen" class="py-16 md:py-24 bg-surface">
  <div class="section-container">
    <div class="max-w-3xl mx-auto text-center mb-12">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">
        Alles, was kleine und mittlere Hotels täglich brauchen.
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
      {features.map(feature => (
        <div class="bg-white rounded-xl p-6 border border-secondary-200 shadow-sm hover:shadow-md transition-shadow duration-200">
          <div class="flex items-start justify-between mb-4">
            <div class="w-10 h-10 rounded-lg bg-primary-50 flex items-center justify-center">
              <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={feature.icon} />
              </svg>
            </div>
            {feature.badge && (
              <span class="text-xs font-medium px-2 py-1 rounded-full bg-accent-100 text-accent-700">
                {feature.badge}
              </span>
            )}
          </div>
          <h3 class="font-semibold text-secondary-900 mb-2">{feature.title}</h3>
          <p class="text-sm text-secondary-600 leading-relaxed">{feature.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
