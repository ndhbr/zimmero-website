---
const bullets = [
  'Ideal für Hotel + Gästehaus + Appartements',
  'Gemeinsame Benutzerverwaltung',
  'Getrennte Zimmerpläne pro Haus',
  'Zentrale Organisationseinstellungen',
  'Unterschiedliche Rollen für Rezeption, Housekeeping, Backoffice, Gastronomie und Hausmeister',
];
---

<section class="py-16 md:py-24 bg-surface">
  <div class="section-container">
    <div class="max-w-4xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-2xl md:text-3xl font-bold mb-4">
            Mehrere Häuser. Ein System.
          </h2>
          <p class="text-secondary-600 leading-relaxed mb-6">
            Verwalten Sie mehrere Properties innerhalb einer Organisation. Wechseln Sie zwischen Häusern, behalten Sie Auslastung und Buchungen im Blick und bilden Sie unterschiedliche Rollen pro Haus ab.
          </p>
          <ul class="space-y-3">
            {bullets.map(item => (
              <li class="flex items-center gap-3 text-secondary-700 text-sm">
                <svg class="w-5 h-5 text-primary-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="relative rounded-xl border border-secondary-200 shadow-sm overflow-hidden bg-white aspect-[4/3] flex items-center justify-center">
          <div class="text-center p-8">
            <div class="flex justify-center gap-3 mb-4">
              <div class="w-12 h-12 rounded-lg bg-primary-100 flex items-center justify-center">
                <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                </svg>
              </div>
              <div class="w-12 h-12 rounded-lg bg-secondary-100 flex items-center justify-center">
                <svg class="w-6 h-6 text-secondary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                </svg>
              </div>
              <div class="w-12 h-12 rounded-lg bg-accent-100 flex items-center justify-center">
                <svg class="w-6 h-6 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z" />
                </svg>
              </div>
            </div>
            <p class="text-sm text-secondary-500">Multi-Property Verwaltung</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
