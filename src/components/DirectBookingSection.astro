---
const benefits = [
  'Buchungsstrecke für die eigene Hotelwebsite',
  'Gäste wählen Zeitraum, Belegung und Zimmerkategorie',
  'Direkte Übergabe ins Zimmero Backoffice',
  'Weniger manuelle Rückfragen',
  'Mehr Direktbuchungen',
  'Ideal für Hotels, Pensionen und Appartementhäuser',
];
---

<section class="py-16 md:py-24">
  <div class="section-container">
    <div class="max-w-4xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-2xl md:text-3xl font-bold mb-4">
            Direkt buchen – ohne Umweg über Portale.
          </h2>
          <p class="text-secondary-600 leading-relaxed mb-6">
            Mit Zimmero können Hotels eine eigene Buchungsstrecke für ihre Website nutzen. Gäste wählen Zeitraum, Belegung und Zimmerkategorie aus und senden die Buchung direkt ab. So bleibt die Anfrage im eigenen System, Ihr Team behält den Überblick und Gäste buchen dort, wo sie ohnehin suchen: auf Ihrer Website.
          </p>
          <ul class="space-y-3">
            {benefits.map(item => (
              <li class="flex items-center gap-3 text-secondary-700 text-sm">
                <svg class="w-5 h-5 text-primary-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="relative rounded-xl border border-secondary-200 shadow-sm overflow-hidden bg-white aspect-[4/3]">
          <img
            src="/screenshots/zimmero-online-buchungsstrecke.webp"
            alt="Zimmero Online-Buchungsstrecke für Hotelwebsites mit Zimmerauswahl"
            width="640"
            height="480"
            class="w-full h-full object-cover"
            loading="lazy"
            onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
          />
          <div class="absolute inset-0 items-center justify-center bg-gradient-to-br from-primary-50 to-secondary-50 hidden">
            <div class="text-center p-8">
              <div class="w-14 h-14 mx-auto mb-3 rounded-lg bg-primary-100 flex items-center justify-center">
                <svg class="w-7 h-7 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
                </svg>
              </div>
              <p class="text-sm text-secondary-500">Online-Buchungsstrecke – Screenshot folgt</p>
            </div>
          </div>
          <div class="absolute inset-0 flex items-center justify-center bg-gradient-to-br from-primary-50 to-secondary-50 screenshot-placeholder">
            <div class="text-center p-8">
              <div class="w-14 h-14 mx-auto mb-3 rounded-lg bg-primary-100 flex items-center justify-center">
                <svg class="w-7 h-7 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
                </svg>
              </div>
              <p class="text-sm text-secondary-500">Online-Buchungsstrecke – Screenshot folgt</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.screenshot-placeholder').forEach(placeholder => {
    const img = placeholder.parentElement?.querySelector('img') as HTMLImageElement;
    if (img?.complete && img.naturalWidth > 0) {
      placeholder.remove();
    } else if (img) {
      img.addEventListener('load', () => placeholder.remove());
    }
  });
</script>
