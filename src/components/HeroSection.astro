---
import { DEMO_URL, CONTACT_EMAIL } from '../config';
---

<section class="pt-16 md:pt-24 pb-12 md:pb-16">
  <div class="section-container">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-sm font-medium text-primary-600 mb-4">
        Für inhabergeführte Hotels, Pensionen und kleine Hotelgruppen
      </p>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-secondary-900 mb-6 leading-tight">
        Zimmero – Die moderne Betriebssoftware für inhabergeführte Hotels
      </h1>
      <p class="text-lg md:text-xl text-secondary-600 mb-8 max-w-3xl mx-auto leading-relaxed">
        Zimmero bringt Zimmerplan, Buchungen, Online-Buchungen, Rechnungen, Housekeeping, Gastronomie-Buchungen, Meldeschein, Kurkarte, Online Check-in, Eigentümerabrechnung und Gästekommunikation in ein einfaches System – entwickelt aus dem echten Hotelalltag.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3 mb-4">
        <a href={DEMO_URL} target="_blank" rel="noopener" class="btn-primary px-8 py-3.5 inline-flex items-center gap-2">
          Demo öffnen
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
        <a href={`mailto:${CONTACT_EMAIL}?subject=Anfrage%3A%20Zimmero%20bekommen`} class="btn-secondary px-8 py-3.5">Pilotphase anfragen</a>
      </div>
      <p class="text-sm text-secondary-500">
        Aktuell in begleiteter Pilotphase für ausgewählte Hotels.
      </p>
    </div>

    <div class="mt-12 md:mt-16 max-w-5xl mx-auto">
      <div class="relative">
        <img
          src="/assets/zimmerplan.webp"
          alt="Zimmero Zimmerplan mit Buchungen, Aufenthalten und blockierten Zimmern"
          class="w-full h-auto block"
          loading="eager"
          onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
        />
        <div class="absolute inset-0 flex items-center justify-center bg-gradient-to-br from-primary-50 to-secondary-50" style="display:none">
          <div class="text-center p-8">
            <div class="w-16 h-16 mx-auto mb-4 rounded-lg bg-primary-100 flex items-center justify-center">
              <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z" />
              </svg>
            </div>
            <p class="text-secondary-600 font-medium">Zimmerplan – Screenshot folgt</p>
          </div>
        </div>
        <!-- Fallback placeholder shown when image not yet available -->
        <div class="absolute inset-0 flex items-center justify-center bg-gradient-to-br from-primary-50 to-secondary-50 placeholder-hero">
          <div class="text-center p-8">
            <div class="w-16 h-16 mx-auto mb-4 rounded-lg bg-primary-100 flex items-center justify-center">
              <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z" />
              </svg>
            </div>
            <p class="text-secondary-600 font-medium">Zimmerplan – Screenshot folgt</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const hero = document.querySelector('.placeholder-hero');
  const img = hero?.previousElementSibling?.previousElementSibling as HTMLImageElement;
  if (img && img.complete && img.naturalWidth > 0) {
    hero?.remove();
  } else if (img) {
    img.addEventListener('load', () => hero?.remove());
  }
</script>
