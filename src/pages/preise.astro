---
import Layout from '../layouts/Layout.astro';
import { CONTACT_EMAIL, DEMO_URL } from '../config';

const plans = [
  {
    name: 'Starter',
    pilot: '79',
    regular: '99',
    target: '1 Haus bis 20 Zimmer',
    suited: 'Pensionen, kleine Hotels, Garni-Hotels',
    features: [
      'Zimmerplan',
      'Buchungen und Angebote',
      'Mailversand mit Vorlagen direkt aus Zimmero',
      'Preischeck',
      'Rechnungen & DATEV-EXTF Export',
      'Housekeeping',
      'Online-Buchungsstrecke',
      'Meldescheinmodul',
      'Gästekommunikation',
      'Automatische Mails (Check-in, Bewertungsmails, …)',
      'Demo- und Onboarding-Unterstützung',
      'Support per E-Mail',
    ],
    highlighted: false,
  },
  {
    name: 'Professional',
    pilot: '149',
    regular: '199',
    target: 'Mehrere Häuser oder bis 50 Zimmer',
    suited: 'Familienhotels, Aparthotels, kleinere Gruppen',
    features: [
      'Alles aus Starter',
      'Multi-Property Verwaltung',
      'Erweiterte Rollen',
      'Eigentümerabrechnung',
      'Mehr operative Workflows',
      '3 Zusatzmodule inklusive',
      'Support per E-Mail und Telefon',
    ],
    highlighted: true,
  },
  {
    name: 'Multi Property',
    pilot: '249',
    regular: '299',
    target: 'Bis 100 Zimmer',
    suited: 'Hotelgruppen, Appartementhäuser, komplexere Betriebe',
    features: [
      'Alles aus Professional',
      'Mehrere Häuser und größere Strukturen',
      'Eigentümergemeinschaften',
      'Erweiterte Abrechnungsszenarien',
      'Priorisierte Betreuung und Entwicklung zugeschnittener Features',
      'Alle Zusatzmodule inklusive (auch zukünftige)',
    ],
    highlighted: false,
  },
];
---

<Layout
  title="Zimmero Preise – Hotelsoftware ab 79 € in der Pilotphase"
  description="Transparente Pilotpreise für Zimmero: moderne Hotelsoftware für inhabergeführte Hotels, Pensionen, Aparthotels und kleine Hotelgruppen."
>
  <section class="pt-16 md:pt-24 pb-16 md:pb-24">
    <div class="section-container">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <h1 class="text-3xl md:text-4xl font-bold mb-4">
          Transparente Pilotpreise für die ersten Hotels.
        </h1>
        <p class="text-secondary-600 leading-relaxed mb-4">
          Zimmero startet mit einer begleiteten Pilotphase für ausgewählte Hotels. Pilotkunden erhalten direkten Einfluss auf die Weiterentwicklung.
        </p>
        <div class="inline-flex items-center gap-2 bg-green-50 border border-green-200 rounded-full px-4 py-2">
          <svg class="w-4 h-4 text-green-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
          </svg>
          <span class="text-sm font-medium text-green-700">Wer jetzt einsteigt, behält den Pilotpreis dauerhaft. Der reguläre Preis gilt nur für spätere Neukunden.</span>
        </div>
        <div class="inline-flex items-center gap-2 bg-primary-50 border border-primary-200 rounded-full px-4 py-2 mt-3">
          <svg class="w-4 h-4 text-primary-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
          </svg>
          <span class="text-sm font-medium text-primary-700">In der Pilotphase: Einrichtung und Schulung kostenlos inklusive.</span>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto mb-8">
        {plans.map(plan => (
          <div class={`rounded-xl p-6 border shadow-sm flex flex-col ${plan.highlighted ? 'border-primary-300 bg-primary-50 ring-1 ring-primary-200' : 'border-secondary-200 bg-white'}`}>
            <div class="mb-4">
              <h2 class="text-lg font-semibold text-secondary-900">{plan.name}</h2>
              <p class="text-sm text-secondary-500 mt-1">{plan.suited}</p>
            </div>
            <div class="mb-4">
              <div class="flex items-baseline gap-1">
                <span class="text-3xl font-bold text-secondary-900">{plan.pilot} &euro;</span>
                <span class="text-sm text-secondary-500">/ Monat</span>
              </div>
              <p class="text-xs text-green-600 font-medium mt-1">Ihr dauerhafter Preis als Pilotkunde</p>
              <p class="text-xs text-secondary-400 mt-0.5">Für spätere Neukunden: {plan.regular} &euro; / Monat</p>
            </div>
            <p class="text-sm text-secondary-600 mb-4 pb-4 border-b border-secondary-200">{plan.target}</p>
            <ul class="space-y-2 flex-1">
              {plan.features.map(f => (
                <li class="flex items-start gap-2 text-sm text-secondary-700">
                  <svg class="w-4 h-4 text-primary-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  {f}
                </li>
              ))}
            </ul>
            <a href={`mailto:${CONTACT_EMAIL}?subject=Anfrage%3A%20Zimmero%20bekommen`} class={`mt-6 text-center py-2.5 rounded-full font-semibold text-sm transition-colors ${plan.highlighted ? 'bg-primary-500 text-white shadow-[0_10px_24px_rgba(74,111,227,0.35)] hover:bg-primary-500/90' : 'border border-secondary-300 text-secondary-700 hover:bg-secondary-50'}`}>
              Pilotphase anfragen
            </a>
          </div>
        ))}
      </div>

      <!-- Individual plan -->
      <div class="max-w-5xl mx-auto">
        <div class="rounded-xl p-6 border border-secondary-200 bg-white shadow-sm flex flex-col md:flex-row items-center justify-between gap-4">
          <div>
            <h2 class="text-lg font-semibold text-secondary-900">Individuell</h2>
            <p class="text-sm text-secondary-600 mt-1">
              Für größere Hotels ab 100 Zimmer, besondere Schnittstellen oder individuelle Prozesse erstellen wir ein passendes Angebot.
            </p>
          </div>
          <a href={`mailto:${CONTACT_EMAIL}?subject=Individuelles%20Angebot`} class="btn-secondary shrink-0">
            Angebot anfragen
          </a>
        </div>
      </div>

      <!-- Add-ons note -->
      <div class="max-w-5xl mx-auto mt-6">
        <div class="rounded-xl border border-secondary-200 bg-white shadow-sm p-6 flex flex-col md:flex-row md:items-center gap-4">
          <div class="w-10 h-10 rounded-lg bg-primary-50 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
            </svg>
          </div>
          <div class="flex-1">
            <p class="font-semibold text-secondary-900 text-sm mb-1">Zusatzmodule</p>
            <p class="text-sm text-secondary-600 leading-relaxed">
              Optionale Erweiterungen wie <strong>Zimmero Bell KI-Assistent</strong>, <strong>Gastronomie per Tablet</strong>, <strong>TSE-Kassen-Anbindung</strong>, <strong>SumUp Bezahlterminal</strong>, <strong>myOBS-Anbindung</strong> oder <strong>Channel Manager mit 50+ OTAs</strong> können flexibel zum jeweiligen Plan hinzugebucht werden.
            </p>
          </div>
          <a href="/#zusatzmodule" class="inline-flex items-center justify-center px-5 py-2.5 rounded-full border border-secondary-300 text-secondary-700 font-semibold text-sm hover:bg-secondary-50 transition-colors shrink-0">
            Zu den Modulen
          </a>
        </div>
      </div>

      <div class="max-w-3xl mx-auto mt-6 text-center">
        <p class="text-sm text-secondary-500 leading-relaxed">
          Alle genannten Preise zzgl. MwSt. Externe Schnittstellen und Add-ons können zusätzliche Kosten durch externe Anbieter verursachen.
        </p>
      </div>
    </div>
  </section>
</Layout>
